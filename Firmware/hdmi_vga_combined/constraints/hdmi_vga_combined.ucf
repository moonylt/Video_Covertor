#============================================================================
# UCF Constraints File: hdmi_vga_combined.ucf
# Project: HDMI + VGA Dual Output Test
# Device: Xilinx Spartan-6 XC6SLX45-3FGG484I
# Date: 2026-03-21
#
# 功能:
# - HDMI 输出: 720p @ 60Hz (TFP410)
# - VGA 输出: 800x600 @ 60Hz (ADV7125)
#
# 硬件连接:
# - TFP410 (U3): HDMI 发送器
# - ADV7125 (U4): VGA DAC
#============================================================================

#============================================================================
# 时钟输入
#============================================================================
# 50MHz 系统时钟 (X2)
NET "clk_50mhz"       LOC = AA12 | IOSTANDARD = LVCMOS33 | PERIOD = 20.000 ns;

#============================================================================
# 全局复位
#============================================================================
NET "rst_n"           LOC = T6   | IOSTANDARD = LVCMOS33 | PULLUP;

#============================================================================
# DDR3L 内存接口 - 固定电平输出 (不使用)
#============================================================================
NET "ddr3_dq[*]"      IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_dqs_p[*]"   IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_dqs_n[*]"   IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_dm[*]"      IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_addr[*]"    IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_ba[*]"      IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_ras_n"      IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_cas_n"      IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_we_n"       IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_reset_n"    IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_ck_p"       IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_ck_n"       IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_cke"        IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_cs_n[*]"    IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_odt[*]"     IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;

#============================================================================
# TFP410 (U3) - HDMI 发送器 (LVCMOS33)
#============================================================================
# 蓝色通道 (D0-D7)
NET "tfp410_dvi_d[0]"   LOC = W10  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[1]"   LOC = T11  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[2]"   LOC = R11  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[3]"   LOC = T12  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[4]"   LOC = U12  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[5]"   LOC = Y12  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[6]"   LOC = V13  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[7]"   LOC = T14  | IOSTANDARD = LVCMOS33 | SLEW = FAST;

# 绿色通道 (D8-D15)
NET "tfp410_dvi_d[8]"   LOC = W14  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[9]"   LOC = AB14 | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[10]"  LOC = Y14  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[11]"  LOC = W15  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[12]"  LOC = AB15 | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[13]"  LOC = T16  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[14]"  LOC = Y16  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[15]"  LOC = AB16 | IOSTANDARD = LVCMOS33 | SLEW = FAST;

# 红色通道 (D16-D23)
NET "tfp410_dvi_d[16]"  LOC = AA16 | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[17]"  LOC = Y17  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[18]"  LOC = AB17 | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[19]"  LOC = V18  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[20]"  LOC = W18  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[21]"  LOC = AB18 | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[22]"  LOC = AA18 | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_dvi_d[23]"  LOC = AB19 | IOSTANDARD = LVCMOS33 | SLEW = FAST;

# 同步和控制信号
NET "tfp410_de"         LOC = Y11  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_hs"         LOC = Y10  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_vs"         LOC = AA10 | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "tfp410_pclk"       LOC = AB12 | IOSTANDARD = LVCMOS33 | SLEW = FAST;

#============================================================================
# ADV7125 (U4) - RGB DAC (VGA 输出)
#============================================================================
# 红色数据 (8位) - R[7:0]
NET "adv7125_red[0]"   LOC = T10  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_red[1]"   LOC = R7   | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_red[2]"   LOC = W9   | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_red[3]"   LOC = W8   | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_red[4]"   LOC = Y8   | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_red[5]"   LOC = AA8  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_red[6]"   LOC = AB8  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_red[7]"   LOC = T7   | IOSTANDARD = LVCMOS33 | SLEW = FAST;

# 绿色数据 (8位) - G[7:0]
NET "adv7125_green[0]" LOC = V7   | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_green[1]" LOC = AB7  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_green[2]" LOC = Y6   | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_green[3]" LOC = AA6  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_green[4]" LOC = AB6  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_green[5]" LOC = W6   | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_green[6]" LOC = U6   | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_green[7]" LOC = AB5  | IOSTANDARD = LVCMOS33 | SLEW = FAST;

# 蓝色数据 (8位) - B[7:0]
NET "adv7125_blue[0]"  LOC = AB4  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_blue[1]"  LOC = AA4  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_blue[2]"  LOC = Y4   | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_blue[3]"  LOC = AB3  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_blue[4]"  LOC = W4   | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_blue[5]"  LOC = Y3   | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_blue[6]"  LOC = AB2  | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_blue[7]"  LOC = AA2  | IOSTANDARD = LVCMOS33 | SLEW = FAST;

# DAC 时钟和控制信号
NET "adv7125_clk"      LOC = AB11 | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "adv7125_blank_n"  LOC = Y5   | IOSTANDARD = LVCMOS33 | SLEW = FAST;

# VGA 同步信号 (连接到 VGA 连接器)
NET "vga_hs"           LOC = T8   | IOSTANDARD = LVCMOS33 | SLEW = FAST;
NET "vga_vs"           LOC = R8   | IOSTANDARD = LVCMOS33 | SLEW = FAST;

#============================================================================
# 用户接口
#============================================================================
# 用户按键 (低有效)
NET "btn_n[0]"         LOC = V11  | IOSTANDARD = LVCMOS33 | PULLUP;
NET "btn_n[1]"         LOC = U10  | IOSTANDARD = LVCMOS33 | PULLUP;

#============================================================================
# 测试点输出
#============================================================================
NET "test_point[0]"    LOC = AF10 | IOSTANDARD = LVCMOS33 | SLEW = FAST | DRIVE = 8;
NET "test_point[1]"    LOC = AG10 | IOSTANDARD = LVCMOS33 | SLEW = FAST | DRIVE = 8;
NET "test_point[2]"    LOC = AH10 | IOSTANDARD = LVCMOS33 | SLEW = FAST | DRIVE = 8;
NET "test_point[3]"    LOC = A11  | IOSTANDARD = LVCMOS33 | SLEW = FAST | DRIVE = 8;

#============================================================================
# 时序约束
#============================================================================
# HDMI 像素时钟: 74.25MHz (720p @ 60Hz)
TIMESPEC "TS_HDMI_CLK" = PERIOD "hdmi_clk" 13.468 ns HIGH 50%;
# VGA 像素时钟: 40MHz (800x600 @ 60Hz)
TIMESPEC "TS_VGA_CLK" = PERIOD "vga_clk" 25.000 ns HIGH 50%;

#============================================================================
# 时钟专用路由约束
#============================================================================
NET "hdmi_clk" CLOCK_DEDICATED_ROUTE = FALSE;
NET "vga_clk" CLOCK_DEDICATED_ROUTE = FALSE;

#============================================================================
# 配置选项
#============================================================================
CONFIG VCCAUX = 3.3;
CONFIG CONFIG_RATE = 50;
#============================================================================
# UCF Constraints File: video_converter.ucf
# Project: VIDEO_CONVERTER FPGA Verification (Minimal Version)
# Device: Xilinx Spartan-6 XC6SLX45-3FGG484I
# Date: 2026-03-16
#
# 注意：
# - DDR3 接口固定为空闲电平
# - SPI Flash 仅用于配置，无需用户逻辑
# - UART 串口未使用
# - ADV7125/ADV7393 视频输出暂时不使用
#============================================================================

#============================================================================
# 时钟输入
#============================================================================
# 50MHz 系统时钟 (X2)
NET "clk_50mhz"       LOC = AA12 | IOSTANDARD = LVCMOS33 | PERIOD = 20.000 ns;
# 27MHz 视频时钟 (X1)
NET "clk_27mhz"       LOC = AB13 | IOSTANDARD = LVCMOS33 | PERIOD = 37.037 ns;

#============================================================================
# 全局复位
#============================================================================
NET "rst_n"           LOC = T6   | IOSTANDARD = LVCMOS33 | PULLUP;

#============================================================================
# DDR3L 内存接口 - 固定电平输出 (不使用 DDR3)
#============================================================================
NET "ddr3_dq[*]"      IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_dqs_p[*]"   IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_dqs_n[*]"   IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_dm[*]"      IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_addr[*]"    IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_ba[*]"      IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_ras_n"      IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_cas_n"      IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_we_n"       IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_reset_n"    IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_ck_p"       IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_ck_n"       IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_cke"        IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_cs_n[*]"    IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;
NET "ddr3_odt[*]"     IOSTANDARD = LVCMOS33 | DRIVE = 4 | SLEW = SLOW;

#============================================================================
# TFP401A (U2) - HDMI 接收器 → FPGA 并行数据输入 (LVCMOS25)
#============================================================================
# 蓝色通道 (D0-D7)
NET "tfp401_dvi_d[0]"   LOC = C5   | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[1]"   LOC = A5   | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[2]"   LOC = D6   | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[3]"   LOC = C6   | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[4]"   LOC = A6   | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[5]"   LOC = B6   | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[6]"   LOC = C7   | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[7]"   LOC = A7   | IOSTANDARD = LVCMOS25;

# 绿色通道 (D8-D15)
NET "tfp401_dvi_d[8]"   LOC = D7   | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[9]"   LOC = D8   | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[10]"  LOC = A8   | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[11]"  LOC = B8   | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[12]"  LOC = C8   | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[13]"  LOC = A9   | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[14]"  LOC = C9   | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[15]"  LOC = D9   | IOSTANDARD = LVCMOS25;

# 红色通道 (D16-D23)
NET "tfp401_dvi_d[16]"  LOC = C14  | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[17]"  LOC = B14  | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[18]"  LOC = A14  | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[19]"  LOC = D15  | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[20]"  LOC = C15  | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[21]"  LOC = A15  | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[22]"  LOC = E16  | IOSTANDARD = LVCMOS25;
NET "tfp401_dvi_d[23]"  LOC = C16  | IOSTANDARD = LVCMOS25;

# 同步和控制信号
NET "tfp401_de"         LOC = C17  | IOSTANDARD = LVCMOS25;
NET "tfp401_hs"         LOC = A18  | IOSTANDARD = LVCMOS25;
NET "tfp401_vs"         LOC = B18  | IOSTANDARD = LVCMOS25;
NET "tfp401_pclk"       LOC = B10  | IOSTANDARD = LVCMOS25;

#============================================================================
# TFP410 (U3) - FPGA 并行数据输出 → HDMI 发射器 (LVCMOS25)
#============================================================================
# 蓝色通道 (D0-D7)
NET "tfp410_dvi_d[0]"   LOC = W10  | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[1]"   LOC = T11  | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[2]"   LOC = R11  | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[3]"   LOC = T12  | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[4]"   LOC = U12  | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[5]"   LOC = Y12  | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[6]"   LOC = V13  | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[7]"   LOC = T14  | IOSTANDARD = LVCMOS25;

# 绿色通道 (D8-D15)
NET "tfp410_dvi_d[8]"   LOC = W14  | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[9]"   LOC = AB14 | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[10]"  LOC = Y14  | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[11]"  LOC = W15  | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[12]"  LOC = AB15 | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[13]"  LOC = T16  | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[14]"  LOC = Y16  | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[15]"  LOC = AB16 | IOSTANDARD = LVCMOS25;

# 红色通道 (D16-D23)
NET "tfp410_dvi_d[16]"  LOC = AA16 | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[17]"  LOC = Y17  | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[18]"  LOC = AB17 | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[19]"  LOC = V18  | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[20]"  LOC = W18  | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[21]"  LOC = AB18 | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[22]"  LOC = AA18 | IOSTANDARD = LVCMOS25;
NET "tfp410_dvi_d[23]"  LOC = AB19 | IOSTANDARD = LVCMOS25;

# 同步和控制信号
NET "tfp410_de"         LOC = Y11  | IOSTANDARD = LVCMOS25;
NET "tfp410_hs"         LOC = Y10  | IOSTANDARD = LVCMOS25;
NET "tfp410_vs"         LOC = AA10 | IOSTANDARD = LVCMOS25;
NET "tfp410_pclk"       LOC = AB12 | IOSTANDARD = LVCMOS25;


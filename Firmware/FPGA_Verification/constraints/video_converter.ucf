#============================================================================
# JTAG 调试接口 (用于下载和调试) - 必须保留
#============================================================================
NET "fpga_tck"         LOC = G15  | IOSTANDARD = LVCMOS33;
NET "fpga_tdi"         LOC = E18  | IOSTANDARD = LVCMOS33;
NET "fpga_tdo"         LOC = A19  | IOSTANDARD = LVCMOS33;
NET "fpga_tms"         LOC = C18  | IOSTANDARD = LVCMOS33;

#============================================================================
# 用户接口 (用于硬件诊断)
#============================================================================
# 用户按键 (低有效)
NET "btn_n[0]"         LOC = V11  | IOSTANDARD = LVCMOS33 | PULLUP;
NET "btn_n[1]"         LOC = U10  | IOSTANDARD = LVCMOS33 | PULLUP;

# LED 指示灯 (诊断状态显示)
NET "led[0]"           LOC = R13  | IOSTANDARD = LVCMOS33 | SLEW = FAST | DRIVE = 8;
NET "led[1]"           LOC = W10  | IOSTANDARD = LVCMOS33 | SLEW = FAST | DRIVE = 8;
NET "led[2]"           LOC = Y10  | IOSTANDARD = LVCMOS33 | SLEW = FAST | DRIVE = 8;
NET "led[3]"           LOC = AA10 | IOSTANDARD = LVCMOS33 | SLEW = FAST | DRIVE = 8;
NET "led[4]"           LOC = AB10 | IOSTANDARD = LVCMOS33 | SLEW = FAST | DRIVE = 8;
NET "led[5]"           LOC = AC10 | IOSTANDARD = LVCMOS33 | SLEW = FAST | DRIVE = 8;
NET "led[6]"           LOC = AD10 | IOSTANDARD = LVCMOS33 | SLEW = FAST | DRIVE = 8;
NET "led[7]"           LOC = AE10 | IOSTANDARD = LVCMOS33 | SLEW = FAST | DRIVE = 8;

#============================================================================
# 测试点输出 (示波器测量点)
#============================================================================
NET "test_point[0]"    LOC = AF10 | IOSTANDARD = LVCMOS33 | SLEW = FAST | DRIVE = 8;
NET "test_point[1]"    LOC = AG10 | IOSTANDARD = LVCMOS33 | SLEW = FAST | DRIVE = 8;
NET "test_point[2]"    LOC = AH10 | IOSTANDARD = LVCMOS33 | SLEW = FAST | DRIVE = 8;
NET "test_point[3]"    LOC = A11  | IOSTANDARD = LVCMOS33 | SLEW = FAST | DRIVE = 8;

#============================================================================
# 时序约束
#============================================================================
TIMESPEC "TS_SYS_CLK" = PERIOD "sys_clk" 10.000 ns HIGH 50%;
TIMESPEC "TS_PIXEL_CLK" = PERIOD "pixel_clk" 13.468 ns HIGH 50%;

#============================================================================
# 时钟专用路由约束 (允许 PLL 时钟驱动外部引脚)
#============================================================================
NET "sys_clk" CLOCK_DEDICATED_ROUTE = FALSE;
NET "pixel_clk" CLOCK_DEDICATED_ROUTE = FALSE;

#============================================================================
# 配置选项
#============================================================================
CONFIG VCCAUX = 3.3;
CONFIG CONFIG_RATE = 50;
